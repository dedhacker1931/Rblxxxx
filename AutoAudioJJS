local function getREPath()
    local ok, result = pcall(function()
        return game:GetService("ReplicatedStorage")
            :WaitForChild("Knit", 10):WaitForChild("Knit", 10)
            :WaitForChild("Services", 10):WaitForChild("JoinService", 10)
            :WaitForChild("RE", 10):WaitForChild("Talk", 10)
    end)
    return ok and result or nil
end

local function getEmoteREPath()
    local ok, result = pcall(function()
        return game:GetService("ReplicatedStorage")
            :WaitForChild("Knit", 10):WaitForChild("Knit", 10)
            :WaitForChild("Services", 10):WaitForChild("EmoteService", 10)
            :WaitForChild("RE", 10):WaitForChild("Emote", 10)
    end)
    return ok and result or nil
end

local function fireSound(index, bypass)
    if soundCooldown then return end
    if not talkRE then talkRE = getREPath() end
    if not talkRE then return end
    soundCooldown = true
    local delay = bypass and 0 or triggerDelay
    if delay > 0 then
        task.delay(delay, function()
            talkRE:FireServer(unpack(sounds[index].args))
            soundCooldown = false
        end)
    else
        talkRE:FireServer(unpack(sounds[index].args))
        task.delay(0.5, function() soundCooldown = false end)
    end
end

local function fireEmote(slotIndex, bypass)
    if emoteCooldown then return end
    if not emoteRE then emoteRE = getEmoteREPath() end
    if not emoteRE then return end
    emoteCooldown = true
    local delay = bypass and 0 or emoteDelay
    if delay > 0 then
        task.delay(delay, function()
            emoteRE:FireServer(slotIndex)
            emoteCooldown = false
        end)
    else
        emoteRE:FireServer(slotIndex)
        task.delay(0.5, function() emoteCooldown = false end)
    end
end

local function getKills()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if not ls then return 0 end
    local k = ls:FindFirstChild("Kills") or ls:FindFirstChild("KOs") or ls:FindFirstChild("kills")
    return k and k.Value or 0
end

local function keyName(kc)
    return tostring(kc):gsub("Enum.KeyCode.", "")
end

local function rebuildSoundKeyMap()
    soundKeyMap = {}
    for i, s in ipairs(sounds) do
        if s.key then soundKeyMap[s.key] = i end
    end
end

local function rebuildEmoteKeyMap()
    emoteKeyMap = {}
    for _, s in ipairs(emoteSlots) do
        if s.key then emoteKeyMap[s.key] = s.index end
    end
end

