local maxDelay = 10

local function updateSlider(input)
    local trackPos = sliderTrack.AbsolutePosition.X
    local trackSize = sliderTrack.AbsoluteSize.X
    local relX = math.clamp(input.Position.X - trackPos, 0, trackSize)
    local fraction = relX / trackSize
    local val = math.floor(fraction * maxDelay * 10 + 0.5) / 10
    if activeTab == 1 then triggerDelay = val else emoteDelay = val end
    sliderFill.Size = UDim2.new(fraction, 0, 1, 0)
    sliderKnob.Position = UDim2.new(fraction, -7, 0.5, -7)
    delayLabel.Text = string.format("Delay: %.1fs", val)
end

sliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        slidingActive = true
        updateSlider(input)
    end
end)

local function switchTab(tab)
    activeTab = tab
    local onTab1 = tab == 1
    tab1Content.Visible = onTab1
    tab2Content.Visible = not onTab1
    tab1Btn.BackgroundColor3 = onTab1 and Color3.fromRGB(80, 60, 160) or Color3.fromRGB(30, 30, 45)
    tab1Btn.TextColor3 = onTab1 and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 160, 180)
    tab2Btn.BackgroundColor3 = onTab1 and Color3.fromRGB(30, 30, 45) or Color3.fromRGB(80, 60, 160)
    tab2Btn.TextColor3 = onTab1 and Color3.fromRGB(160, 160, 180) or Color3.fromRGB(255, 255, 255)
    local val = onTab1 and triggerDelay or emoteDelay
    local fraction = val / maxDelay
    sliderFill.Size = UDim2.new(fraction, 0, 1, 0)
    sliderKnob.Position = UDim2.new(fraction, -7, 0.5, -7)
    delayLabel.Text = string.format("Delay: %.1fs", val)
    if not onTab1 then refreshEmoteSlots() end
end

tab1Btn.MouseButton1Click:Connect(function() switchTab(1) end)
tab2Btn.MouseButton1Click:Connect(function() switchTab(2) end)

