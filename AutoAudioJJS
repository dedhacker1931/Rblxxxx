local soundButtons = {}

local function updateSelection()
    for i, row in ipairs(soundButtons) do
        if i == selectedIndex then
            row.nameBtn.BackgroundColor3 = Color3.fromRGB(80, 60, 160)
            row.nameBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            row.nameBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
            row.nameBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
        end
    end
end

local function setListening(index)
    listeningIndex = index
    for i, row in ipairs(soundButtons) do
        if i == index then
            row.keyBtn.Text = "..."
            row.keyBtn.TextColor3 = Color3.fromRGB(255, 220, 80)
