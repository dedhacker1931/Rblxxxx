UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if emoteListeningSlot ~= nil then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local target = emoteListeningSlot
            emoteListeningSlot = nil
            for _, sd in ipairs(emoteSlots) do
                if sd.index == target then sd.key = input.KeyCode break end
            end
            rebuildEmoteKeyMap()
            for _, row in ipairs(emoteRowObjects) do
                if row.slotIndex == target then
                    row.keyBtn.Text = keyName(input.KeyCode)
                    row.keyBtn.TextColor3 = Color3.fromRGB(160, 130, 255)
                    row.keyStroke.Color = Color3.fromRGB(80, 80, 120)
                    break
                end
            end
        end
        return
    end

    if listeningIndex then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local idx = listeningIndex
            listeningIndex = nil
            sounds[idx].key = input.KeyCode
            rebuildSoundKeyMap()
            local row = soundButtons[idx]
            row.keyBtn.Text = keyName(input.KeyCode)
            row.keyBtn.TextColor3 = Color3.fromRGB(160, 130, 255)
            row.keyStroke.Color = Color3.fromRGB(80, 80, 120)
        end
        return
    end

    if input.UserInputType == Enum.UserInputType.Keyboard and not gameProcessed then
        local si = soundKeyMap[input.KeyCode]
        if si then fireSound(si, true) end
        local ei = emoteKeyMap[input.KeyCode]
        if ei then fireEmote(ei, true) end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        if mainDragging then
            local delta = input.Position - mainDragStart
            mainFrame.Position = UDim2.new(
                mainStartPos.X.Scale, mainStartPos.X.Offset + delta.X,
                mainStartPos.Y.Scale, mainStartPos.Y.Offset + delta.Y
            )
        end
        if slidingActive then updateSlider(input) end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        mainDragging = false
        slidingActive = false
    end
end)

RunService.Heartbeat:Connect(function()
    local now = tick()
    if now - lastHeartbeatCheck < HEARTBEAT_INTERVAL then return end
    lastHeartbeatCheck = now
    local currentKills = getKills()
    if lastKills == nil then
        lastKills = currentKills
        return
    end
    if currentKills > lastKills then
        lastKills = currentKills
        if autoEnabled then fireSound(selectedIndex, false) end
        if emoteAutoEnabled then fireEmote(emoteSelectedSlot, false) end
    end
end)
