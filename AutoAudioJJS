-- Float button drag & click logic

toggleFloatBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        tbDragging = true
        tbDragMoved = false
        tbDragStart = input.Position
        tbStartPos = toggleFloatBtn.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if tbDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - tbDragStart
        if math.abs(delta.X) > 4 or math.abs(delta.Y) > 4 then
            tbDragMoved = true
        end
        toggleFloatBtn.Position = UDim2.new(
            tbStartPos.X.Scale, tbStartPos.X.Offset + delta.X,
            tbStartPos.Y.Scale, tbStartPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and tbDragging then
        tbDragging = false
        if not tbDragMoved then
            guiVisible = not guiVisible
            mainFrame.Visible = guiVisible
            toggleFloatBtn.BackgroundColor3 = guiVisible
                and Color3.fromRGB(30, 30, 45)
                or Color3.fromRGB(80, 60, 160)
        end
    end
end)

