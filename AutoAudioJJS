local maxDelay = 10

local function updateSlider(input)
    local trackPos = sliderTrack.AbsolutePosition.X
    local trackSize = sliderTrack.AbsoluteSize.X
    local relX = math.clamp(input.Position.X - trackPos, 0, trackSize)
    local fraction = relX / trackSize
    local val = math.floor(fraction * maxDelay * 10 + 0.5) / 10
    if activeTab == 1 then
        triggerDelay = val
    else
        emoteDelay = val
    end
    sliderFill.Size = UDim2.new(fraction, 0, 1, 0)
    sliderKnob.Position = UDim2.new(fraction, -7, 0.5, -7)
    delayLabel.Text = string.format("Delay: %.1fs", val)
end

sliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        slidingActive = true
        updateSlider(input)
    end
end)

local function switchTab(tab)
    activeTab = tab
    if tab == 1 then
        tab1Content.Visible = true
        tab2Content.Visible = false
        tab1Btn.BackgroundColor3 = Color3.fromRGB(80, 60, 160)
        tab1Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        tab2Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
        tab2Btn.TextColor3 = Color3.fromRGB(160, 160, 180)
        local fraction = triggerDelay / maxDelay
        sliderFill.Size = UDim2.new(fraction, 0, 1, 0)
        sliderKnob.Position = UDim2.new(fraction, -7, 0.5, -7)
        delayLabel.Text = string.format("Delay: %.1fs", triggerDelay)
    else
        tab1Content.Visible = false
        tab2Content.Visible = true
        tab1Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
        tab1Btn.TextColor3 = Color3.fromRGB(160, 160, 180)
