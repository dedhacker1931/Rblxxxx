local function updateEmoteSelection()
    for _, row in ipairs(emoteRowObjects) do
        local sel = row.slotIndex == emoteSelectedSlot
        row.nameBtn.BackgroundColor3 = sel and Color3.fromRGB(80, 60, 160) or Color3.fromRGB(30, 30, 45)
        row.nameBtn.TextColor3 = sel and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 200)
    end
end

local function refreshEmoteSlots()
    for _, row in ipairs(emoteRowObjects) do
        row.frame:Destroy()
    end
    emoteRowObjects = {}

    local ok, Page1 = pcall(function()
        return LocalPlayer.PlayerGui:WaitForChild("Emotes", 3)
            :WaitForChild("Emote", 3):WaitForChild("Page1", 3)
    end)

    local fresh = {}
    if ok then
        for i = 1, 8 do
            local slot = Page1:FindFirstChild(tostring(i))
            if slot then
                local lbl = slot:FindFirstChild("EmoteName")
                local name = lbl and lbl.ContentText or "None"
                if name ~= "" and name ~= "None" then
                    local existingKey = nil
                    for _, old in ipairs(emoteSlots) do
                        if old.index == i then existingKey = old.key break end
                    end
                    table.insert(fresh, {index = i, name = name, key = existingKey})
                end
            end
        end
    end
    emoteSlots = fresh
    rebuildEmoteKeyMap()

    emoteScroll.CanvasSize = UDim2.new(0, 0, 0, #emoteSlots * 46 + 8)

    for _, slotData in ipairs(emoteSlots) do
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, -12, 0, 38)
        frame.BackgroundTransparency = 1
        frame.Parent = emoteScroll

        -- name button (narrower to fit key + clear)
        local nameBtn = Instance.new("TextButton")
        nameBtn.Size = UDim2.new(1, -118, 1, 0)
        nameBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
        nameBtn.BorderSizePixel = 0
        nameBtn.Text = "Slot " .. slotData.index .. ": " .. slotData.name
        nameBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
        nameBtn.TextSize = 12
        nameBtn.Font = Enum.Font.Gotham
        nameBtn.TextXAlignment = Enum.TextXAlignment.Left
        nameBtn.TextTruncate = Enum.TextTruncate.AtEnd
        nameBtn.Parent = frame

        local namePad = Instance.new("UIPadding")
        namePad.PaddingLeft = UDim.new(0, 8)
        namePad.Parent = nameBtn

        local nameCorner = Instance.new("UICorner")
        nameCorner.CornerRadius = UDim.new(0, 6)
        nameCorner.Parent = nameBtn

        local keyBtn = Instance.new("TextButton")
        keyBtn.Size = UDim2.new(0, 68, 1, 0)
        keyBtn.Position = UDim2.new(1, -112, 0, 0)
        keyBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 38)
        keyBtn.BorderSizePixel = 0
        keyBtn.Text = slotData.key and keyName(slotData.key) or "None"
        keyBtn.TextColor3 = slotData.key and Color3.fromRGB(160, 130, 255) or Color3.fromRGB(180, 180, 200)
        keyBtn.TextSize = 11
        keyBtn.Font = Enum.Font.Gotham
        keyBtn.Parent = frame

        local keyCorner = Instance.new("UICorner")
        keyCorner.CornerRadius = UDim.new(0, 6)
        keyCorner.Parent = keyBtn

        local keyStroke = Instance.new("UIStroke")
        keyStroke.Color = Color3.fromRGB(80, 80, 120)
        keyStroke.Thickness = 1
        keyStroke.Parent = keyBtn

        local clearBtn = Instance.new("TextButton")
        clearBtn.Size = UDim2.new(0, 36, 1, 0)
        clearBtn.Position = UDim2.new(1, -38, 0, 0)
        clearBtn.BackgroundColor3 = Color3.fromRGB(100, 30, 30)
        clearBtn.BorderSizePixel = 0
        clearBtn.Text = "✕"
        clearBtn.TextColor3 = Color3.fromRGB(255, 180, 180)
        clearBtn.TextSize = 13
        clearBtn.Font = Enum.Font.GothamBold
        clearBtn.Parent = frame

        local clearCorner = Instance.new("UICorner")
        clearCorner.CornerRadius = UDim.new(0, 6)
        clearCorner.Parent = clearBtn

        local si = slotData.index

        nameBtn.MouseButton1Click:Connect(function()
            emoteSelectedSlot = si
            updateEmoteSelection()
        end)
        nameBtn.MouseEnter:Connect(function()
            if si ~= emoteSelectedSlot then nameBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 75) end
        end)
        nameBtn.MouseLeave:Connect(function()
            if si ~= emoteSelectedSlot then nameBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45) end
        end)

        keyBtn.MouseButton1Click:Connect(function()
            emoteListeningSlot = si
            keyBtn.Text = "..."
            keyBtn.TextColor3 = Color3.fromRGB(255, 220, 80)
            keyStroke.Color = Color3.fromRGB(255, 220, 80)
        end)

        clearBtn.MouseButton1Click:Connect(function()
            for _, sd in ipairs(emoteSlots) do
                if sd.index == si then sd.key = nil break end
            end
            rebuildEmoteKeyMap()
            keyBtn.Text = "None"
            keyBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
            keyStroke.Color = Color3.fromRGB(80, 80, 120)
            if emoteListeningSlot == si then emoteListeningSlot = nil end
        end)

        table.insert(emoteRowObjects, {
            frame = frame, nameBtn = nameBtn,
            keyBtn = keyBtn, keyStroke = keyStroke, slotIndex = si,
        })
    end

    updateEmoteSelection()
end

