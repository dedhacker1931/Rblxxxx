titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

tabBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    -- emote slot keybind recording
    if emoteListeningSlot ~= nil then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local targetSlot = emoteListeningSlot
            emoteListeningSlot = nil
            for _, slotData in ipairs(emoteSlots) do
                if slotData.index == targetSlot then
                    slotData.key = input.KeyCode
                    break
                end
            end
            for _, row in ipairs(emoteRowObjects) do
                if row.slotIndex == targetSlot then
                    row.keyBtn.Text = keyName(input.KeyCode)
                    row.keyBtn.TextColor3 = Color3.fromRGB(160, 130, 255)
                    row.keyStroke.Color = Color3.fromRGB(80, 80, 120)
                    break
                end
            end
        end
        return
    end

    -- sound keybind recording
    if listeningIndex then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local idx = listeningIndex
            sounds[idx].key = input.KeyCode
            local row = soundButtons[idx]
            row.keyBtn.Text = keyName(input.KeyCode)
            row.keyBtn.TextColor3 = Color3.fromRGB(160, 130, 255)
            row.keyStroke.Color = Color3.fromRGB(80, 80, 120)
            listeningIndex = nil
        end
        return
    end

    if input.UserInputType == Enum.UserInputType.Keyboard and not gameProcessed then
        -- check emote keybinds
        for _, slotData in ipairs(emoteSlots) do
            if slotData.key and input.KeyCode == slotData.key then
                fireEmoteSlot(slotData.index, true)
                break
            end
        end
        -- check sound keybinds
        for i, sound in ipairs(sounds) do
            if sound.key and input.KeyCode == sound.key then
                fireSound(i, true)
                break
            end
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        if dragging then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
        if slidingActive then
            updateSlider(input)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
        slidingActive = false
    end
end)

-- Kill detection — lastKills starts as nil so first read just initializes it

RunService.Heartbeat:Connect(function()
    local currentKills = getKills()
    if lastKills == nil then
        lastKills = currentKills
        return
    end
    if currentKills > lastKills then
        lastKills = currentKills
        if autoEnabled then
            fireSound(selectedIndex, false)
        end
        if emoteAutoEnabled then
            fireEmoteSlot(emoteSelectedSlot, false)
        end
    end
end)
