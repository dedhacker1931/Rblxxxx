local function updateEmoteSelection()
    for _, row in ipairs(emoteRowObjects) do
        if row.slotIndex == emoteSelectedSlot then
            row.nameBtn.BackgroundColor3 = Color3.fromRGB(80, 60, 160)
            row.nameBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            row.nameBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
            row.nameBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
        end
    end
end

local function refreshEmoteSlots()
    for _, row in ipairs(emoteRowObjects) do
        row.frame:Destroy()
    end
    emoteRowObjects = {}

    local success, Page1 = pcall(function()
        return LocalPlayer.PlayerGui:WaitForChild("Emotes", 3)
            :WaitForChild("Emote", 3)
            :WaitForChild("Page1", 3)
    end)

    local freshSlots = {}
    if success then
        for i = 1, 8 do
            local slot = Page1:FindFirstChild(tostring(i))
            if slot then
                local nameLabel = slot:FindFirstChild("EmoteName")
                local emoteName = nameLabel and nameLabel.ContentText or "None"
                if emoteName and emoteName ~= "" and emoteName ~= "None" then
                    -- preserve existing keybind if slot index matches
                    local existingKey = nil
                    for _, old in ipairs(emoteSlots) do
                        if old.index == i then
                            existingKey = old.key
                            break
                        end
                    end
                    table.insert(freshSlots, {index = i, name = emoteName, key = existingKey})
                end
            end
        end
    end
    emoteSlots = freshSlots

    emoteScroll.CanvasSize = UDim2.new(0, 0, 0, #emoteSlots * 46 + 8)

    for _, slotData in ipairs(emoteSlots) do
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, -12, 0, 38)
        frame.BackgroundTransparency = 1
        frame.Parent = emoteScroll

        local nameBtn = Instance.new("TextButton")
        nameBtn.Size = UDim2.new(1, -74, 1, 0)
        nameBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
        nameBtn.BorderSizePixel = 0
        nameBtn.Text = "Slot " .. slotData.index .. ": " .. slotData.name
        nameBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
        nameBtn.TextSize = 12
        nameBtn.Font = Enum.Font.Gotham
        nameBtn.TextXAlignment = Enum.TextXAlignment.Left
        nameBtn.TextTruncate = Enum.TextTruncate.AtEnd
        nameBtn.Parent = frame

        local nameBtnPad = Instance.new("UIPadding")
        nameBtnPad.PaddingLeft = UDim.new(0, 8)
        nameBtnPad.Parent = nameBtn

        local nameBtnCorner = Instance.new("UICorner")
        nameBtnCorner.CornerRadius = UDim.new(0, 6)
        nameBtnCorner.Parent = nameBtn

        local keyBtn = Instance.new("TextButton")
        keyBtn.Size = UDim2.new(0, 68, 1, 0)
        keyBtn.Position = UDim2.new(1, -68, 0, 0)
        keyBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 38)
        keyBtn.BorderSizePixel = 0
        keyBtn.Text = slotData.key and keyName(slotData.key) or "None"
        keyBtn.TextColor3 = slotData.key and Color3.fromRGB(160, 130, 255) or Color3.fromRGB(180, 180, 200)
        keyBtn.TextSize = 11
        keyBtn.Font = Enum.Font.Gotham
        keyBtn.Parent = frame

        local keyBtnCorner = Instance.new("UICorner")
        keyBtnCorner.CornerRadius = UDim.new(0, 6)
        keyBtnCorner.Parent = keyBtn

        local keyStroke = Instance.new("UIStroke")
        keyStroke.Color = slotData.key and Color3.fromRGB(80, 80, 120) or Color3.fromRGB(80, 80, 120)
        keyStroke.Thickness = 1
        keyStroke.Parent = keyBtn

        local si = slotData.index

        nameBtn.MouseButton1Click:Connect(function()
            emoteSelectedSlot = si
            updateEmoteSelection()
        end)

        nameBtn.MouseEnter:Connect(function()
            if si ~= emoteSelectedSlot then
                nameBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 75)
            end
        end)

        nameBtn.MouseLeave:Connect(function()
            if si ~= emoteSelectedSlot then
                nameBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
            end
        end)

        keyBtn.MouseButton1Click:Connect(function()
            emoteListeningSlot = si
            keyBtn.Text = "..."
            keyBtn.TextColor3 = Color3.fromRGB(255, 220, 80)
            keyStroke.Color = Color3.fromRGB(255, 220, 80)
        end)

        table.insert(emoteRowObjects, {
            frame = frame,
            nameBtn = nameBtn,
            keyBtn = keyBtn,
            keyStroke = keyStroke,
            slotIndex = si,
        })
    end

    updateEmoteSelection()
end

