local function getREPath()
    local success, result = pcall(function()
        return game:GetService("ReplicatedStorage")
            :WaitForChild("Knit", 10)
            :WaitForChild("Knit", 10)
            :WaitForChild("Services", 10)
            :WaitForChild("JoinService", 10)
            :WaitForChild("RE", 10)
            :WaitForChild("Talk", 10)
    end)
    if success then return result end
    return nil
end

local function getEmoteREPath()
    local success, result = pcall(function()
        return game:GetService("ReplicatedStorage")
            :WaitForChild("Knit", 10)
            :WaitForChild("Knit", 10)
            :WaitForChild("Services", 10)
            :WaitForChild("EmoteService", 10)
            :WaitForChild("RE", 10)
            :WaitForChild("Emote", 10)
    end)
    if success then return result end
    return nil
end

local emoteRE = nil

local function fireEmoteSlot(slotIndex, bypass)
    if not emoteRE then emoteRE = getEmoteREPath() end
    if emoteRE and not emoteCooldown then
        emoteCooldown = true
        if bypass then
            emoteRE:FireServer(slotIndex)
            task.delay(1, function() emoteCooldown = false end)
        else
            task.delay(emoteDelay, function()
                emoteRE:FireServer(slotIndex)
                task.delay(1, function() emoteCooldown = false end)
            end)
        end
    end
end

local function getKills()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if not leaderstats then return 0 end
    local kills = leaderstats:FindFirstChild("Kills") or leaderstats:FindFirstChild("KOs") or leaderstats:FindFirstChild("kills")
    if kills then return kills.Value end
    return 0
end

local function fireSoundIndex(index)
    if not talkRE then talkRE = getREPath() end
    if talkRE then
        talkRE:FireServer(unpack(sounds[index].args))
    end
end

local function fireSound(index, bypass)
    if not talkRE then talkRE = getREPath() end
    if talkRE and not cooldown then
        cooldown = true
        if bypass then
            fireSoundIndex(index)
            task.delay(1, function() cooldown = false end)
        else
            task.delay(triggerDelay, function()
                fireSoundIndex(index)
                task.delay(1, function() cooldown = false end)
            end)
        end
    end
end

local function keyName(keyCode)
    return tostring(keyCode):gsub("Enum.KeyCode.", "")
end

